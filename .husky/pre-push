#!/bin/sh
set -eu

if [ -f "$(dirname "$0")/_/husky.sh" ]; then
  . "$(dirname "$0")/_/husky.sh"
fi

echo "🔄 Running Playbook release sync..."
pnpm playbook release sync --json --out .playbook/release-plan.json >/dev/null

# Stage release sync results for commit.
git add .

if ! git diff --cached --quiet; then
  echo "📦 Committing release sync changes..."
  git commit -m "chore: sync release plan" --no-verify
fi

echo "🔍 Verifying release sync clean state..."
if ! pnpm playbook release sync --check --json --out .playbook/release-plan.json >/dev/null; then
  echo "❌ Release sync still not clean. Blocking push."
  exit 1
fi

if [ -n "$(git status --porcelain)" ]; then
  echo "❌ Working tree is still dirty after release sync. Blocking push."
  exit 1
fi

echo "✅ Release state clean. Proceeding with push."
