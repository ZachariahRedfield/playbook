#!/bin/sh
set -eu

if [ -f "$(dirname "$0")/_/husky.sh" ]; then
  . "$(dirname "$0")/_/husky.sh"
fi

# Avoid unnecessary release guard runs on commits with no staged content.
if git diff --cached --quiet; then
  exit 0
fi

echo "🔄 Running release guard before commit..."
pnpm release:guard

git update-index --again

echo "✅ Release guard passed"
