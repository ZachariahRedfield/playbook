{
  "extends": "./tsconfig.json",
  "include": ["src/**/*"],
  "exclude": ["test", "**/*.test.ts", "**/*.spec.ts"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "types": ["node"]
  }
}
