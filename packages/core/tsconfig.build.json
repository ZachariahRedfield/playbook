{
  "extends": "./tsconfig.json",
  "include": [
    "src/**/*"
  ],
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": false,
    "declarationMap": true,
    "outDir": "dist",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "types": [
      "node"
    ]
  },
  "exclude": [
    "test",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
