{
  "name": "@zachariahredfield/playbook-core",
  "version": "0.1.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:types",
    "build:js": "pnpm exec tsc -p tsconfig.build.json --emitDeclarationOnly false --declaration false",
    "build:types": "pnpm exec tsc -p tsconfig.build.json",
    "test": "pnpm exec vitest run --passWithNoTests"
  },
  "devDependencies": {},
  "publishConfig": {
    "access": "public"
  }
}
