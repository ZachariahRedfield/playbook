{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/execution-outcome-input.schema.json",
  "title": "Fleet Adoption Execution Outcome Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "generated_at", "session_id", "prompt_outcomes"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "kind": { "const": "fleet-adoption-execution-outcome-input" },
    "generated_at": { "type": "string" },
    "session_id": { "type": "string" },
    "prompt_outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["prompt_id", "repo_id", "lane_id", "status"],
        "properties": {
          "prompt_id": { "type": "string" },
          "repo_id": { "type": "string" },
          "lane_id": { "type": "string" },
          "status": { "enum": ["succeeded", "failed", "partial", "not_run"] },
          "verification_passed": { "type": ["boolean", "null"] },
          "notes": { "type": "string" },
          "observed_transition": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to"],
            "properties": {
              "from": { "$ref": "https://playbook.dev/schemas/execution-receipt.schema.json#/$defs/lifecycleStage" },
              "to": { "$ref": "https://playbook.dev/schemas/execution-receipt.schema.json#/$defs/lifecycleStage" }
            }
          },
          "blockers": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["blocker_code", "message"],
              "properties": {
                "blocker_code": { "type": "string" },
                "message": { "type": "string" },
                "evidence": { "type": "string" }
              }
            }
          },
          "artifact_deltas": {
            "type": "array",
            "items": { "$ref": "https://playbook.dev/schemas/execution-receipt.schema.json#/$defs/artifactDelta" }
          }
        }
      }
    }
  }
}
