{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/graph-informed-learning.schema.json",
  "title": "PlaybookGraphInformedLearningArtifact",
  "description": "Deterministic additive, read-only graph enrichment for canonical learning clusters.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "generatedAt",
    "proposalOnly",
    "reviewOnly",
    "sourceArtifacts",
    "clusters"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "kind": { "const": "graph-informed-learning" },
    "generatedAt": { "type": "string", "minLength": 1 },
    "proposalOnly": { "const": true },
    "reviewOnly": { "const": true },
    "sourceArtifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          ".playbook/learning-clusters.json",
          ".playbook/repo-graph.json",
          ".playbook/repo-index.json"
        ]
      },
      "uniqueItems": true
    },
    "clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "clusterId",
          "dimension",
          "relatedModules",
          "dependencyNeighborhoodSummary",
          "sharedGovernanceRuleSurfaces",
          "structuralConcentration",
          "graphInformedRationale",
          "learningCluster"
        ],
        "properties": {
          "clusterId": { "type": "string", "minLength": 1, "pattern": "^cluster:" },
          "dimension": {
            "enum": [
              "repeated_failure_shape",
              "repeated_remediation_outcome",
              "repeated_query_usage_pattern",
              "repeated_governance_blocker"
            ]
          },
          "relatedModules": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "dependencyNeighborhoodSummary": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "directDependencies",
              "directDependents",
              "adjacentModuleCount",
              "dependencyEdgesWithinNeighborhood"
            ],
            "properties": {
              "directDependencies": { "type": "integer", "minimum": 0 },
              "directDependents": { "type": "integer", "minimum": 0 },
              "adjacentModuleCount": { "type": "integer", "minimum": 0 },
              "dependencyEdgesWithinNeighborhood": { "type": "integer", "minimum": 0 }
            }
          },
          "sharedGovernanceRuleSurfaces": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "structuralConcentration": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "moduleCoverageRatio",
              "neighborhoodSpreadRatio",
              "governanceCoverageRatio",
              "classification"
            ],
            "properties": {
              "moduleCoverageRatio": { "type": "number", "minimum": 0, "maximum": 1 },
              "neighborhoodSpreadRatio": { "type": "number", "minimum": 0, "maximum": 1 },
              "governanceCoverageRatio": { "type": "number", "minimum": 0, "maximum": 1 },
              "classification": { "enum": ["concentrated", "balanced", "spread"] }
            }
          },
          "graphInformedRationale": { "type": "string", "minLength": 1 },
          "learningCluster": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "clusterId",
              "dimension",
              "sourceEvidenceRefs",
              "repeatedSignalSummary",
              "suggestedImprovementCandidateType",
              "confidence",
              "riskReviewRequirement",
              "nextActionText"
            ],
            "properties": {
              "clusterId": { "type": "string", "minLength": 1, "pattern": "^cluster:" },
              "dimension": {
                "enum": [
                  "repeated_failure_shape",
                  "repeated_remediation_outcome",
                  "repeated_query_usage_pattern",
                  "repeated_governance_blocker"
                ]
              },
              "sourceEvidenceRefs": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              },
              "repeatedSignalSummary": { "type": "string", "minLength": 1 },
              "suggestedImprovementCandidateType": {
                "enum": [
                  "repair_class_investigation",
                  "threshold_tuning",
                  "verify_rule_improvement",
                  "docs_doctrine_update",
                  "query_experience_hardening"
                ]
              },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "riskReviewRequirement": {
                "enum": ["none", "maintainer-review", "governance-review"]
              },
              "nextActionText": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
