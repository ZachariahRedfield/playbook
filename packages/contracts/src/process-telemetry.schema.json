{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/process-telemetry.schema.json",
  "title": "PlaybookProcessTelemetry",
  "description": "Deterministic additive execution/process telemetry for workflow learning evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "generatedAt", "records", "summary"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "kind": { "const": "process-telemetry" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "records": {
      "type": "array",
      "items": { "$ref": "#/$defs/ProcessRecord" }
    },
    "summary": { "$ref": "#/$defs/ProcessSummary" }
  },
  "$defs": {
    "ProcessRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "recordedAt",
        "task_family",
        "task_duration_ms",
        "files_touched",
        "validators_run",
        "retry_count",
        "merge_conflict_risk",
        "first_pass_success",
        "prompt_size",
        "reasoning_scope"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "recordedAt": { "type": "string", "format": "date-time" },
        "task_family": { "type": "string", "minLength": 1 },
        "task_profile_id": { "type": "string", "minLength": 1 },
        "route_id": { "type": "string", "minLength": 1 },
        "task_duration_ms": { "type": "integer", "minimum": 0 },
        "files_touched": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "validators_run": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "rule_packs_selected": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "required_validations_selected": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "optional_validations_selected": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "validation_duration_ms": { "type": "integer", "minimum": 0 },
        "planning_duration_ms": { "type": "integer", "minimum": 0 },
        "apply_duration_ms": { "type": "integer", "minimum": 0 },
        "retry_count": { "type": "integer", "minimum": 0 },
        "merge_conflict_risk": { "type": "number", "minimum": 0, "maximum": 1 },
        "actual_merge_conflict": { "type": "boolean" },
        "first_pass_success": { "type": "boolean" },
        "human_intervention_required": { "type": "boolean" },
        "parallel_lane_count": { "type": "integer", "minimum": 1 },
        "over_validation_signal": { "type": "boolean" },
        "under_validation_signal": { "type": "boolean" },
        "prompt_size": { "type": "integer", "minimum": 0 },
        "reasoning_scope": { "type": "string", "enum": ["narrow", "module", "repository", "cross-repo"] }
      }
    },
    "ReasoningScopeCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["narrow", "module", "repository", "cross-repo"],
      "properties": {
        "narrow": { "type": "integer", "minimum": 0 },
        "module": { "type": "integer", "minimum": 0 },
        "repository": { "type": "integer", "minimum": 0 },
        "cross-repo": { "type": "integer", "minimum": 0 }
      }
    },
    "ProcessSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_records",
        "total_task_duration_ms",
        "average_task_duration_ms",
        "total_retry_count",
        "first_pass_success_count",
        "average_merge_conflict_risk",
        "total_files_touched_unique",
        "total_validators_run_unique",
        "task_family_counts",
        "validators_run_counts",
        "reasoning_scope_counts",
        "route_id_counts",
        "task_profile_id_counts",
        "rule_packs_selected_counts",
        "required_validations_selected_counts",
        "optional_validations_selected_counts",
        "total_validation_duration_ms",
        "total_planning_duration_ms",
        "total_apply_duration_ms",
        "human_intervention_required_count",
        "actual_merge_conflict_count",
        "average_parallel_lane_count",
        "over_validation_signal_count",
        "under_validation_signal_count"
      ],
      "properties": {
        "total_records": { "type": "integer", "minimum": 0 },
        "total_task_duration_ms": { "type": "integer", "minimum": 0 },
        "average_task_duration_ms": { "type": "number", "minimum": 0 },
        "total_retry_count": { "type": "integer", "minimum": 0 },
        "first_pass_success_count": { "type": "integer", "minimum": 0 },
        "average_merge_conflict_risk": { "type": "number", "minimum": 0, "maximum": 1 },
        "total_files_touched_unique": { "type": "integer", "minimum": 0 },
        "total_validators_run_unique": { "type": "integer", "minimum": 0 },
        "task_family_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "validators_run_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "reasoning_scope_counts": { "$ref": "#/$defs/ReasoningScopeCounts" },
        "route_id_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "task_profile_id_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "rule_packs_selected_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "required_validations_selected_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "optional_validations_selected_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "total_validation_duration_ms": { "type": "integer", "minimum": 0 },
        "total_planning_duration_ms": { "type": "integer", "minimum": 0 },
        "total_apply_duration_ms": { "type": "integer", "minimum": 0 },
        "human_intervention_required_count": { "type": "integer", "minimum": 0 },
        "actual_merge_conflict_count": { "type": "integer", "minimum": 0 },
        "average_parallel_lane_count": { "type": "number", "minimum": 0 },
        "over_validation_signal_count": { "type": "integer", "minimum": 0 },
        "under_validation_signal_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
