{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/pattern-candidates.schema.json",
  "title": "Pattern Candidates Artifact",
  "description": "Deterministic read-only artifact contract for extracted structural pattern observations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "generatedAt",
    "candidates"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "kind": {
      "type": "string",
      "const": "pattern-candidates"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "candidates": {
      "type": "array",
      "description": "Additive list of extracted candidate observations. Entries should be emitted in deterministic id order.",
      "items": {
        "$ref": "#/$defs/patternCandidate"
      }
    }
  },
  "$defs": {
    "patternCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "pattern_family",
        "title",
        "description",
        "source_artifact",
        "signals",
        "confidence",
        "evidence_refs",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "pattern_family": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "source_artifact": {
          "type": "string",
          "minLength": 1
        },
        "signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "observed",
            "triaged",
            "accepted",
            "rejected"
          ]
        }
      }
    }
  }
}
