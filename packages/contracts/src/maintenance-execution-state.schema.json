{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/maintenance-execution-state.schema.json",
  "title": "Playbook Maintenance Execution State",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "updatedAt", "lastReceiptPath", "runs"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "kind": { "const": "playbook-maintenance-execution-state" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "lastReceiptPath": { "const": ".playbook/maintenance-execution-receipt.json" },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["maintenanceId", "taskId", "status", "executedAt", "approvalRef", "policyRef"],
        "properties": {
          "maintenanceId": { "type": "string", "minLength": 1 },
          "taskId": { "type": "string", "minLength": 1 },
          "status": { "enum": ["executed", "failed"] },
          "executedAt": { "type": "string", "format": "date-time" },
          "approvalRef": { "type": "string", "minLength": 1 },
          "policyRef": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
