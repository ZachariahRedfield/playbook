{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/maintenance-execution-receipt.schema.json",
  "title": "Playbook Maintenance Execution Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "generatedAt", "sourcePlan", "sourceApprovals", "sourcePolicy", "summary", "outcomes"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "kind": { "const": "playbook-maintenance-execution-receipt" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sourcePlan": { "type": "string", "minLength": 1 },
    "sourceApprovals": { "type": "string", "minLength": 1 },
    "sourcePolicy": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executed", "failed", "total"],
      "properties": {
        "executed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      }
    },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["taskId", "maintenanceId", "maintenanceType", "command", "status", "boundedTargetSurface", "approvalRef", "policyRef", "sourceEvidenceRefs", "exitCode", "message"],
        "properties": {
          "taskId": { "type": "string", "minLength": 1 },
          "maintenanceId": { "type": "string", "minLength": 1 },
          "maintenanceType": { "type": "string", "minLength": 1 },
          "command": { "type": "string", "minLength": 1 },
          "status": { "enum": ["executed", "failed"] },
          "boundedTargetSurface": { "type": "string", "minLength": 1 },
          "approvalRef": { "type": "string", "minLength": 1 },
          "policyRef": { "type": "string", "minLength": 1 },
          "sourceEvidenceRefs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "exitCode": { "type": "integer" },
          "message": { "type": "string" }
        }
      }
    }
  }
}
